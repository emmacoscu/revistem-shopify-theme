{% doc %}
  @prompt
    I want to design a “compatibility” section for a premium hair supplement brand (Revistem).
    
    Context:
    - Brand positioning: clinical, evidence-based, premium
    - Audience: people already using medical treatments (finasteride, dutasteride, minoxidil)
    - Tone: honest, professional, non-marketing, non-aggressive
    - Aesthetic: minimal, clean, inspired by Aesop / The Ordinary
    
    Core message:
    “Compatible con tu protocolo”
    
    Goal:
    Communicate clearly that the product is designed to complement medical treatments without interference.
    
    Requirements:
    - Short, highly scannable section
    - Title + short paragraph + optional supporting elements
    - Avoid long text blocks
    - Can include 2–3 supporting bullet points if useful
    - No exaggerated claims
    
    Design direction:
    - Clean layout with generous white space
    - Could include subtle icons or visual cues (medical / clinical style)
    - No heavy UI (no cards, no bright colors)
    - Elegant alignment (centered or left-aligned)
    
    Also:
    - Suggest refined Spanish copy (keep tone clinical and trustworthy)
    - Suggest 2–3 alternative ways to express compatibility (short variations)
    - Suggest icon ideas (if used)
    
    Output:
    - Final Spanish copy (title + body + optional bullets)
    - Layout suggestion
    - Visual / icon direction
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-compatibility-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    display: block;
  }

  .ai-compatibility-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-compatibility-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    line-height: 1.2;
  }

  .ai-compatibility-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin: 0 0 {{ block.settings.body_spacing }}px 0;
    opacity: {{ block.settings.body_opacity }};
  }

  .ai-compatibility-body-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-compatibility-bullets-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: {{ block.settings.bullets_top_spacing }}px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.bullets_gap }}px;
    {% if block.settings.text_alignment == 'center' %}
      align-items: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-items: flex-end;
    {% else %}
      align-items: flex-start;
    {% endif %}
  }

  .ai-compatibility-bullet-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    font-size: {{ block.settings.bullet_size }}px;
    color: {{ block.settings.bullet_color }};
    line-height: 1.5;
  }

  .ai-compatibility-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-compatibility-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
  }

  @media screen and (max-width: 749px) {
    .ai-compatibility-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 16px;
    }

    .ai-compatibility-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-compatibility-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-compatibility-bullet-{{ ai_gen_id }} {
      font-size: {{ block.settings.bullet_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-compatibility-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-compatibility-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-compatibility-title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </h2>
    {% endif %}

    {% if block.settings.body_text != blank %}
      <div class="ai-compatibility-body-{{ ai_gen_id }}">
        {{ block.settings.body_text }}
      </div>
    {% endif %}

    {% if block.settings.show_bullets %}
      <ul class="ai-compatibility-bullets-{{ ai_gen_id }}">
        {% if block.settings.bullet_1 != blank %}
          <li class="ai-compatibility-bullet-{{ ai_gen_id }}">
            <span class="ai-compatibility-icon-{{ ai_gen_id }}">
              {% if block.settings.icon_style == 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% elsif block.settings.icon_style == 'plus' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              {% elsif block.settings.icon_style == 'circle' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2">
                  <circle cx="12" cy="12" r="8"></circle>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3h18v18H3z"></path>
                  <path d="M9 9h6v6H9z"></path>
                </svg>
              {% endif %}
            </span>
            <span>{{ block.settings.bullet_1 }}</span>
          </li>
        {% endif %}

        {% if block.settings.bullet_2 != blank %}
          <li class="ai-compatibility-bullet-{{ ai_gen_id }}">
            <span class="ai-compatibility-icon-{{ ai_gen_id }}">
              {% if block.settings.icon_style == 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% elsif block.settings.icon_style == 'plus' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              {% elsif block.settings.icon_style == 'circle' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2">
                  <circle cx="12" cy="12" r="8"></circle>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3h18v18H3z"></path>
                  <path d="M9 9h6v6H9z"></path>
                </svg>
              {% endif %}
            </span>
            <span>{{ block.settings.bullet_2 }}</span>
          </li>
        {% endif %}

        {% if block.settings.bullet_3 != blank %}
          <li class="ai-compatibility-bullet-{{ ai_gen_id }}">
            <span class="ai-compatibility-icon-{{ ai_gen_id }}">
              {% if block.settings.icon_style == 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% elsif block.settings.icon_style == 'plus' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              {% elsif block.settings.icon_style == 'circle' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2">
                  <circle cx="12" cy="12" r="8"></circle>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3h18v18H3z"></path>
                  <path d="M9 9h6v6H9z"></path>
                </svg>
              {% endif %}
            </span>
            <span>{{ block.settings.bullet_3 }}</span>
          </li>
        {% endif %}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Compatibility section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Compatible con tu protocolo"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Formulado para complementar tratamientos médicos como finasterida, dutasterida y minoxidil. Sin interferencias, sin contraindicaciones.</p>"
    },
    {
      "type": "header",
      "content": "Bullet points"
    },
    {
      "type": "checkbox",
      "id": "show_bullets",
      "label": "Show bullet points",
      "default": true
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet 1",
      "default": "No interfiere con tratamientos farmacológicos"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet 2",
      "default": "Ingredientes clínicamente estudiados"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet 3",
      "default": "Apto para uso prolongado"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        {
          "value": "check",
          "label": "Check mark"
        },
        {
          "value": "plus",
          "label": "Plus sign"
        },
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "medical",
          "label": "Medical cross"
        }
