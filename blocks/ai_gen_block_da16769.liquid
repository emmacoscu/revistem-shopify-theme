{% doc %}
  @prompt
    I want to design a final “brand philosophy / closing statement” section for a premium hair supplement brand (Revistem).
    
    Context:
    - Brand tone: clinical, honest, minimal, evidence-based
    - No exaggerated claims, no marketing hype
    - Aesthetic: editorial, clean, similar to Aesop / The Ordinary
    - This is the closing section of the page
    
    Core message:
    “Revistem no busca sustituir tratamientos.
    Busca complementarlos con criterio.
    Porque entender el problema es el primer paso para tratarlo bien.”
    
    Goal:
    Create a strong, memorable closing that reinforces trust and brand philosophy.
    
    Requirements:
    - Very minimal design
    - Large typography for main statement
    - Short supporting line (optional)
    - No buttons or distractions
    - Should feel calm, confident, and premium
    
    Design direction:
    - Centered layout
    - Lots of white space
    - Typography-driven (quote style)
    - Subtle visual separation from previous section
    
    Also:
    - Refine the Spanish copy while keeping the same meaning
    - Provide 2–3 variations of the statement (same tone)
    - Suggest hierarchy (what goes big, what goes small)
    
    Output:
    - Final Spanish copy (main + optional supporting line)
    - Layout description
    - Typography/style recommendation
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-statement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-statement__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-brand-statement__main-{{ ai_gen_id }} {
    font-family: {{ block.settings.main_font.family }}, {{ block.settings.main_font.fallback_families }};
    font-weight: {{ block.settings.main_font.weight }};
    font-size: {{ block.settings.main_font_size }}px;
    line-height: {{ block.settings.main_line_height }};
    color: {{ block.settings.main_text_color }};
    margin: 0 0 {{ block.settings.spacing_between }}px 0;
    letter-spacing: {{ block.settings.main_letter_spacing }}px;
  }

  .ai-brand-statement__supporting-{{ ai_gen_id }} {
    font-family: {{ block.settings.supporting_font.family }}, {{ block.settings.supporting_font.fallback_families }};
    font-weight: {{ block.settings.supporting_font.weight }};
    font-size: {{ block.settings.supporting_font_size }}px;
    line-height: {{ block.settings.supporting_line_height }};
    color: {{ block.settings.supporting_text_color }};
    margin: 0;
    opacity: {{ block.settings.supporting_opacity | divided_by: 100.0 }};
    letter-spacing: {{ block.settings.supporting_letter_spacing }}px;
  }

  .ai-brand-statement__divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin_top }}px auto {{ block.settings.divider_margin_bottom }}px;
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-brand-statement-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 16px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-brand-statement__main-{{ ai_gen_id }} {
      font-size: {{ block.settings.main_font_size_mobile }}px;
      line-height: {{ block.settings.main_line_height_mobile }};
    }

    .ai-brand-statement__supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.supporting_font_size_mobile }}px;
      line-height: {{ block.settings.supporting_line_height_mobile }};
    }
  }
{% endstyle %}

<div class="ai-brand-statement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-statement__container-{{ ai_gen_id }}">
    {% if block.settings.show_divider_top %}
      <div class="ai-brand-statement__divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.main_statement != blank %}
      <div class="ai-brand-statement__main-{{ ai_gen_id }}">
        {{ block.settings.main_statement }}
      </div>
    {% endif %}

    {% if block.settings.supporting_line != blank %}
      <div class="ai-brand-statement__supporting-{{ ai_gen_id }}">
        {{ block.settings.supporting_line }}
      </div>
    {% endif %}

    {% if block.settings.show_divider_bottom %}
      <div class="ai-brand-statement__divider-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</div>

