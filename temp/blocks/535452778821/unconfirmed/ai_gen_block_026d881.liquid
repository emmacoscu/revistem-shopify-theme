{% doc %}
  @prompt
    Design a “compatibility with treatment” section for a premium hair supplement brand (Revistem).
    
    Goal:
    Build trust and reduce friction for users already following hair loss treatments.
    
    Tone:
    - Clinical, calm, precise
    - No medical claims
    - No exaggeration
    
    Content:
    Revistem está formulado para complementar protocolos activos...
    
    Requirements:
    - Structure in 2 clear parts:
      1. Main message (2–3 short paragraphs)
      2. Disclaimer (smaller text)
    
    - Keep sentences short and clear
    - Avoid complex medical language
    - Make it easy to scan
    
    Design:
    - Minimal layout
    - Left-aligned text
    - Strong title + lighter body
    - Disclaimer visually separated (smaller font or lower contrast)
    - Plenty of white space
    
    Optional:
    - Add subtle divider between main text and disclaimer
    
    Output:
    - Final Spanish copy
    - Suggested hierarchy (title, body, disclaimer)
    - Layout recommendation
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-compatibility-section-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-compatibility-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-compatibility-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    line-height: 1.2;
    text-align: left;
  }

  .ai-compatibility-content-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-compatibility-content-{{ ai_gen_id }} p {
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
    text-align: left;
  }

  .ai-compatibility-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-compatibility-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_spacing }}px 0;
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  .ai-compatibility-disclaimer-{{ ai_gen_id }} {
    margin-top: {{ block.settings.disclaimer_spacing }}px;
  }

  .ai-compatibility-disclaimer-{{ ai_gen_id }} p {
    font-size: {{ block.settings.disclaimer_size }}px;
    line-height: {{ block.settings.disclaimer_line_height }};
    color: {{ block.settings.disclaimer_color }};
    margin: 0 0 {{ block.settings.disclaimer_paragraph_spacing }}px 0;
    text-align: left;
  }

  .ai-compatibility-disclaimer-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-compatibility-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-compatibility-content-{{ ai_gen_id }} p {
      font-size: {{ block.settings.body_size_mobile }}px;
    }

    .ai-compatibility-disclaimer-{{ ai_gen_id }} p {
      font-size: {{ block.settings.disclaimer_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-compatibility-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-compatibility-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-compatibility-title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </h2>
    {% endif %}

    {% if block.settings.main_content != blank %}
      <div class="ai-compatibility-content-{{ ai_gen_id }}">
        {{ block.settings.main_content }}
      </div>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-compatibility-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.disclaimer != blank %}
      <div class="ai-compatibility-disclaimer-{{ ai_gen_id }}">
        {{ block.settings.disclaimer }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
