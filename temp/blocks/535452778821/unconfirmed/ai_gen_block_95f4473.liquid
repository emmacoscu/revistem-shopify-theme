{% doc %}
  @prompt
    I want to design a “certifications / trust logos” section for a premium health supplement brand (Revistem).
    
    Context:
    - Brand tone: clinical, minimal, premium (not marketplace / not dropshipping)
    - Goal: build trust and credibility without looking crowded or cheap
    - These logos represent manufacturer certifications (GMP, ISO, EFSA, AECOC, Ministerio de Sanidad, etc.)
    
    Placement:
    - This section will be placed just before the FAQ on the homepage
    
    Design requirements:
    - Keep it minimal and clean
    - Logos should not be too large (subtle, not dominant)
    - Maintain generous white space
    - Align with premium brands (Aesop, The Ordinary style)
    
    Layout options:
    - Prefer a horizontal row of logos (desktop)
    - On mobile: either a swipeable row OR 2 rows of logos (well spaced)
    - Avoid carousel autoplay (feels cheap)
    - Logos should be evenly spaced and aligned
    
    Styling:
    - Use monochrome or slightly desaturated versions of the logos if possible (avoid too many colors)
    - Reduce opacity slightly (e.g. 80–90%) to make them feel integrated
    - Same visual weight for all logos (normalize sizes)
    
    Section content:
    - Add a small title above (subtle, not big)
    
    Title options (Spanish):
    - “Certificaciones”
    - “Fabricado bajo estándares certificados”
    - “Certificaciones y estándares”
    
    Optional subtitle (very subtle):
    - “Fabricado bajo estándares europeos de calidad y seguridad”
    
    Avoid:
    - Big icons
    - Heavy borders or cards
    - Too much contrast
    - Marketing-style badges
    
    Output:
    - Suggested layout (desktop + mobile)
    - Final section title (Spanish)
    - Spacing and sizing recommendations
    - Whether to use carousel or static layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-certifications-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-certifications-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-certifications-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-certifications-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px;
    letter-spacing: 0.5px;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-certifications-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    opacity: {{ block.settings.subtitle_opacity | divided_by: 100.0 }};
    font-weight: 300;
    letter-spacing: 0.3px;
  }

  .ai-certifications-logos-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-certifications-logo-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: {{ block.settings.logo_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-certifications-logo-item-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-certifications-logo-item-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_max_width }}px;
    max-height: {{ block.settings.logo_max_height }}px;
    width: auto;
    height: auto;
    object-fit: contain;
    {% if block.settings.grayscale %}
      filter: grayscale({{ block.settings.grayscale_amount }}%);
    {% endif %}
  }

  .ai-certifications-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_max_width }}px;
    height: {{ block.settings.logo_max_height }}px;
    background-color: #f5f5f5;
    border: 1px dashed #d0d0d0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-certifications-logo-placeholder-{{ ai_gen_id }} svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-certifications-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 0 {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-certifications-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-certifications-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_mobile }}px;
    }

    .ai-certifications-logos-{{ ai_gen_id }} {
      gap: {{ block.settings.logo_spacing_mobile }}px;
      {% if block.settings.mobile_layout == 'two_rows' %}
        max-width: 100%;
      {% endif %}
    }

    .ai-certifications-logo-item-{{ ai_gen_id }} img {
      max-width: {{ block.settings.logo_max_width_mobile }}px;
      max-height: {{ block.settings.logo_max_height_mobile }}px;
    }

    .ai-certifications-logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.logo_max_width_mobile }}px;
      height: {{ block.settings.logo_max_height_mobile }}px;
    }

    {% if block.settings.mobile_layout == 'scroll' %}
      .ai-certifications-logos-{{ ai_gen_id }} {
        overflow-x: auto;
        overflow-y: hidden;
        flex-wrap: nowrap;
        justify-content: flex-start;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding-bottom: 10px;
      }

      .ai-certifications-logos-{{ ai_gen_id }}::-webkit-scrollbar {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-certifications-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-certifications-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-certifications-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-certifications-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-certifications-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-certifications-logos-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign logo = block.settings[logo_key]
        %}
        
        {% if logo != blank %}
          <div class="ai-certifications-logo-item-{{ ai_gen_id }}">
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ logo.width }}"
              height="{{ logo.height }}"
            >
          </div>
        {% elsif i <= 5 %}
          <div class="ai-certifications-logo-item-{{ ai_gen_id }}">
            <div class="ai-certifications-logo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

