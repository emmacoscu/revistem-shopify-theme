{% doc %}
  @prompt
    Design a premium “brand origin” section for a science-based hair supplement brand (Revistem).
    
    Tone:
    - Rational, evidence-based, non-marketing
    - Founder explanation, not storytelling cliché
    - No hype, no exaggeration
    
    Content (Spanish, refine but keep meaning):
    Revistem nació de una búsqueda personal...
    
    Requirements:
    - Break into 4–5 short paragraphs (max 2–3 lines each)
    - Clear logical flow:
      1. búsqueda personal
      2. problema del mercado
      3. frustración con soluciones existentes
      4. decisión de formular desde cero
      5. cierre
    
    - Improve readability and flow
    - Keep tone serious and credible
    - Avoid emotional or inspirational language
    
    Design:
    - Background color: #F9F2E9
    - Left-aligned text
    - Narrow readable width (editorial style)
    - High vertical spacing between paragraphs
    - No cards, no boxes
    - Clean typography hierarchy
    
    Output:
    - Final Spanish copy
    - Paragraph structure
    - Suggested spacing and layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-origin-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    width: 100%;
    display: block;
  }

  .ai-brand-origin-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    margin: 0;
  }

  .ai-brand-origin-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-brand-origin-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.text_opacity | divided_by: 100.0 }};
  }

  .ai-brand-origin-paragraph-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-origin-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-brand-origin-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-brand-origin-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      margin-bottom: {{ block.settings.paragraph_spacing_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-brand-origin-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-origin-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-brand-origin-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.paragraph_1 != blank %}
      <div class="ai-brand-origin-paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_1 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_2 != blank %}
      <div class="ai-brand-origin-paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_2 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_3 != blank %}
      <div class="ai-brand-origin-paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_3 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_4 != blank %}
      <div class="ai-brand-origin-paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_4 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_5 != blank %}
      <div class="ai-brand-origin-paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_5 }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
