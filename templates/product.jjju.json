tory_threshold":12,"show_inventory_bar":true,"show_inventory_pill":true,"text_soldout":"Unfortunately this item is sold-out!","text_untracked":"Currently this item has stock!","text_low_one":"Hurry up! Only 1 item is in stock","text_low_many":"Hurry up! Only [qty] items are in stock.","text_normal":"Currently [qty] items are in stock!","inv_bar_height":1,"inv_bar_radius":0,"inv_bar_width_normal":100,"inv_bar_width_low":62,"inv_bar_width_untrack":50,"inv_bar_width_sold":0,"normal_pill_color":"#23c460","normal_color":"#23c460","normal_color_2":"#23c460","low_pill_color":"#ff0e0e","low_color":"#ea0404","low_color_2":"#fdc11b","untrack_pill_color":"#008763","untrack_background_bar":"#008763","sold_pill_color":"#c8c8c8","background_bar":"#e4e4e4"}},"description_kzKRHC":{"type":"description","settings":{}},"icon_with_text_XwWjGC":{"type":"icon-with-text","settings":{"layout":"horizontal","icon_1":"truck","heading_1":"Envío rápido","icon_2":"leaf","heading_2":"Totalmente orgánica","icon_3":"heart","heading_3":"Hecho con amor"}},"shipping_CGrYT3":{"type":"shipping","settings":{"ship_days":5,"skip_saturday":true,"skip_sunday":true,"cut_off_time":24,"hide_icon":false,"icon_size":20,"image_ani":"none","text_size":10,"text_style":"uppercase","text":"Order in (timer) and Get delivery By (date)","hours":"h","minutes":"m","date_locale":"en-US","ship_bg":"rgba(0,0,0,0)","show_border":false,"ship_border":"#f2f2f2","border_radius":0,"padding_top":12,"padding_bottom":0,"margin_top":16,"margin_bottom":0}},"buy_buttons":{"type":"buy_buttons","settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true,"skip_cart":false,"button_padding_top":20,"button_padding_bottom":20,"button_custom_style":false,"button_font_size":20,"button_height":45,"lm_main_button":"#000000","lm_main_button_gr":"","lm_main_text":"#ffffff","lm_main_text_hover":"#0b57d0","lm_main_button_hover":"#ffffff","lm_main_button_gr_hover":"","lm_main_button_border_width":0,"lm_main_button_border_color":"#000000"}},"collapsible_tab_ptCdTk":{"type":"collapsible_tab","settings":{"heading":"Qué esRevistem Hair Forte","icon":"question_mark","content":"<p>Revistem Hair Forte es la versión más avanzada<br\/>de nuestra línea capilar.<\/p><p>Su fórmula parte de la misma base estructural<br\/>y nutricional de Revistem Hair, pero añade una capa extra de soporte<br\/>antioxidante y sistémico con ingredientes seleccionados para ampliar el enfoque<br\/>de la fórmula.<\/p><p>Está pensado para quienes buscan una<br\/>formulación más completa, sin perder coherencia ni caer en mezclas<br\/>innecesarias.<\/p>","page":"","open_by_default":false,"show_product_description":false}},"collapsible_tab_EBKNVc":{"type":"collapsible_tab","settings":{"heading":"Qué lohace diferente","icon":"star","content":"<p>Hair Forte amplía la fórmula base con una<br\/>selección de compuestos orientados a un soporte más completo del entorno<br\/>biológico del folículo.<\/p><p>La fórmula combina:<\/p><p>Base estructural capilar<br\/><br\/>Con NAC, L-cistina y L-metionina.<\/p><p>Eje vegetal capilar<br\/><br\/>Con saw palmetto y extracto de mijo.<\/p><p>Soporte antioxidante ampliado<br\/><br\/>Con resveratrol, astaxantina, vitamina E, vitamina C y coenzima Q10.<\/p><p>Soporte nutricional y sistémico<br\/><br\/>Con zinc, selenio, biotina, vitamina D y vitamina K.<\/p><p>Es una fórmula pensada para quienes quieren ir<br\/>un paso más allá dentro de una estrategia capilar seria.<\/p>","page":"","open_by_default":false,"show_product_description":false}},"collapsible_tab_Adeqcw":{"type":"collapsible_tab","settings":{"heading":"Ingredientes principales","icon":"fire","content":"<p>NAC (N-acetil-L-cisteína) – 399 mg<br\/><br\/>Extracto seco de saw palmetto – 320 mg<br\/><br\/>(45 % ácidos grasos)<\/p><p>Vitamina E – 150 mg a-TE<br\/><br\/>Extracto seco de mijo – 150 mg<br\/><br\/>L-cistina – 150 mg<br\/><br\/>L-metionina – 150 mg<br\/><br\/>Extracto de Polygonum cuspidatum – 102 mg<br\/><br\/>(98 % resveratrol)<\/p><p>Oleorresina rica en astaxantina de alga<br\/>Haematococcus pluvialis – 80 mg<br\/><br\/>(5 % astaxantina = 4 mg)<\/p><p>Vitamina C – 80 mg<br\/><br\/>Zinc – 15 mg<br\/><br\/>Coenzima Q10 – 50 mg<br\/><br\/>Selenio – 55 μg<br\/><br\/>Biotina – 2000 μg<br\/><br\/>Vitamina K – 100 μg<br\/><br\/>Vitamina D – 50 μg<\/p>","page":"","open_by_default":false,"show_product_description":false}},"collapsible_tab_K8PCaK":{"type":"collapsible_tab","settings":{"heading":"Beneficios\/ información nutricional","icon":"heart","content":"<p>El zinc y la biotina contribuyen al<br\/>mantenimiento del cabello en condiciones normales.<\/p><p>El selenio contribuye al mantenimiento del<br\/>cabello y las uñas en condiciones normales.<\/p><p>La vitamina C y la vitamina E contribuyen a la<br\/>protección de las células frente al daño oxidativo.<\/p><p>La vitamina D contribuye al funcionamiento<br\/>normal del sistema inmunitario.<\/p><p>La vitamina K contribuye al mantenimiento de los huesos<br\/>en condiciones normales.<br\/><br\/><br\/><br\/><\/p>","page":"","open_by_default":false,"show_product_description":false}},"collapsible_tab_tN7hJQ":{"type":"collapsible_tab","settings":{"heading":"Cómotomarlo","icon":"check_mark","content":"<p>Dosis diaria recomendada: 3 cápsulas al día.<\/p><p>Modo de empleo: tomar 3 cápsulas al día,<br\/>preferiblemente con comida.<\/p><p>Duración del envase: 30 días<\/p>","page":"","open_by_default":false,"show_product_description":false}},"collapsible_tab_kzPLfE":{"type":"collapsible_tab","settings":{"heading":"Ingredientes completos","icon":"clipboard","content":"<p>N-acetil-L-cisteína (NAC), cápsula (agente de<br\/>recubrimiento: hidroxipropilmetilcelulosa y colorante: óxido de hierro),<br\/>extracto seco de fruto de saw palmetto (Serenoa repens, 45 % ácidos grasos),<br\/>DL-alfa tocoferol (vitamina E), extracto seco de mijo (Panicum miliaceum L.,<br\/>fruto-semilla), L-cistina, L-metionina, agente de carga (celulosa<br\/>microcristalina), extracto seco de Polygonum cuspidatum (98 % resveratrol),<br\/>oleorresina rica en astaxantina del alga Haematococcus pluvialis, ácido<br\/>L-ascórbico (vitamina C), bisglicinato de zinc, coenzima Q10, antiaglomerante<br\/>(sales magnésicas de ácidos grasos), L-seleniometionina, D-biotina (biotina),<br\/>menaquinona (vitamina K) y colecalciferol (vitamina D)<strong>.<\/strong><\/p>","page":"","open_by_default":false,"show_product_description":false}},"collapsible_tab_RybkgE":{"type":"collapsible_tab","settings":{"heading":"Advertencias","icon":"lightning_bolt","content":"<p>Los complementos alimenticios no deben<br\/>utilizarse como sustitutos de una dieta variada y equilibrada y un estilo de<br\/>vida saludable.<\/p><p>No superar la dosis diaria recomendada.<\/p><p>Mantener fuera del alcance de los niños más<br\/>pequeños.<\/p><p>Conservar en lugar fresco y seco, protegido de<br\/>la luz solar.<\/p><p>No debe ser consumido el mismo día junto con<br\/>otros complementos alimenticios que contengan ésteres de astaxantina.<\/p><p>No debe ser consumido por lactantes ni niños<br\/>menores de 10 años.<\/p><p>Producto para uso en adultos.<\/p><p>Desaconsejado en mujeres embarazadas o en periodo de<br\/>lactancia.<br\/><br\/><br\/><br\/><\/p>","page":"","open_by_default":false,"show_product_description":false}}},"block_order":["breadcrumbs_tr4UFi","review_mMj4kD","title_Fnnnm3","price","trust_feature_xnRc3U","inventory_4fpVhP","description_kzKRHC","icon_with_text_XwWjGC","shipping_CGrYT3","buy_buttons","collapsible_tab_ptCdTk","collapsible_tab_EBKNVc","collapsible_tab_Adeqcw","collapsible_tab_K8PCaK","collapsible_tab_tN7hJQ","collapsible_tab_kzPLfE","collapsible_tab_RybkgE"],"custom_css":[],"settings":{"enable_sticky_info":true,"no_scroll":false,"show_feature_image_first":true,"color_scheme":"background-1","block_padding":1.5,"media_size":"medium","constrain_to_viewport":false,"media_fit":"cover","gallery_layout":"vertical_left","hide_slider_buttons":false,"thumbnail_layout":"medium","thumbnail_size":